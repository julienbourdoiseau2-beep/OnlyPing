# =========================
# Local defaults
# =========================
DATABASE_URL="postgresql://onlyping:onlyping@localhost:5432/onlyping?schema=public"
DIRECT_URL="postgresql://onlyping:onlyping@localhost:5432/onlyping?schema=public"
NEXTAUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-me-in-production"
RESEND_API_KEY=""
EMAIL_FROM="no-reply@onlypingtt.com"
ADMIN_EMAIL="admin@onlyping.fr"
STRIPE_SECRET_KEY="sk_test_xxx"
STRIPE_WEBHOOK_SECRET="whsec_xxx"

# =========================
# Production (Cloudflare R2)
# =========================
# Definir ces variables dans l'hebergeur pour activer le stockage R2.
R2_ENDPOINT="https://<accountid>.r2.cloudflarestorage.com"
R2_BUCKET="onlyping-videos"
R2_REGION="auto"
R2_ACCESS_KEY_ID="<r2-access-key-id>"
R2_SECRET_ACCESS_KEY="<r2-secret-access-key>"
R2_PUBLIC_BASE_URL="https://pub-xxxxxxxx.r2.dev"